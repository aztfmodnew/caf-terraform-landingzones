---
# AVM alz-lib architecture definition
# Generated by Ansible from archetype_config_overrides.caf.platform.yaml + custom_landing_zones.caf.platform.yaml
# This file is consumed by the alz Terraform provider via library_references custom_url.
# Filename after rendering: {{ bootstrap.management_groups[region][tfstate].management_group_prefix }}.alz_architecture_definition.yaml
#
# exists: true  → MG already exists in Azure (migration from enterprise_scale)
# exists: false → MG will be created by Terraform
#
# Set bootstrap.management_groups[region][tfstate].alz_existing_deployment: true when
# migrating from an existing enterprise_scale deployment to keep exists: true for standard MGs.
{% set root_id = bootstrap.management_groups[region][tfstate].management_group_prefix %}
{% set root_name = bootstrap.management_groups[region][tfstate].management_group_name %}
{% set existing = bootstrap.management_groups[region][tfstate].alz_existing_deployment | default(false) %}
name: "{{ root_id }}"
management_groups:

  # --- Standard ALZ management group hierarchy ---

  - id: "{{ root_id }}"
    display_name: "{{ root_name }}"
    archetypes:
      - "{{ mg.archetype_definitions.root.archetype_id | default('root') }}"
    parent_id: null
    exists: {{ existing | string | lower }}

  - id: "{{ root_id }}-decommissioned"
    display_name: "Decommissioned"
    archetypes:
      - "{{ mg.archetype_definitions['decommissioned'].archetype_id | default('decommissioned') }}"
    parent_id: "{{ root_id }}"
    exists: {{ existing | string | lower }}

  - id: "{{ root_id }}-sandboxes"
    display_name: "Sandboxes"
    archetypes:
      - "{{ mg.archetype_definitions['sandboxes'].archetype_id | default('sandboxes') }}"
    parent_id: "{{ root_id }}"
    exists: {{ existing | string | lower }}

  - id: "{{ root_id }}-landing-zones"
    display_name: "Landing Zones"
    archetypes:
      - "{{ mg.archetype_definitions['landing-zones'].archetype_id | default('landing_zones') }}"
    parent_id: "{{ root_id }}"
    exists: {{ existing | string | lower }}

  - id: "{{ root_id }}-platform"
    display_name: "Platform"
    archetypes:
      - "{{ mg.archetype_definitions['platform'].archetype_id | default('platform') }}"
    parent_id: "{{ root_id }}"
    exists: {{ existing | string | lower }}

  - id: "{{ root_id }}-connectivity"
    display_name: "Connectivity"
    archetypes:
      - "{{ mg.archetype_definitions['connectivity'].archetype_id | default('connectivity') }}"
    parent_id: "{{ root_id }}-platform"
    exists: {{ existing | string | lower }}

  - id: "{{ root_id }}-management"
    display_name: "Management"
    archetypes:
      - "{{ mg.archetype_definitions['management'].archetype_id | default('management') }}"
    parent_id: "{{ root_id }}-platform"
    exists: {{ existing | string | lower }}

  - id: "{{ root_id }}-identity"
    display_name: "Identity"
    archetypes:
      - "{{ mg.archetype_definitions['identity'].archetype_id | default('identity') }}"
    parent_id: "{{ root_id }}-platform"
    exists: {{ existing | string | lower }}

{% if mg_custom.archetype_definitions is defined %}
  # --- Custom landing zones (from custom_landing_zones.caf.platform.yaml) ---

{% for key, level in mg_custom.archetype_definitions.items() %}
  - id: "{{ root_id }}-{{ key }}"
    display_name: "{{ level.display_name }}"
    archetypes:
      - "{{ level.archetype_id }}"
    parent_id: "{{ root_id }}-{{ level.parent_management_group_id }}"
    exists: false
{% endfor %}
{% endif %}
