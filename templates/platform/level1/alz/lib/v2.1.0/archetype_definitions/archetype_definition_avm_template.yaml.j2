{% endfor %}
{% endif %}
{% if mg.archetype_definitions[item].policy_definitions is mapping %}
policy_definitions:
{% for key in mg.archetype_definitions[item].policy_definitions.keys() %}
  - "{{ key }}"
{% endfor %}
{% endif %}
{% if mg.archetype_definitions[item].policy_set_definitions is mapping %}
policy_set_definitions:
{% for key in mg.archetype_definitions[item].policy_set_definitions.keys() %}
